    "mailparser": "^3.7.1",
    "mammoth": "^1.8.0",
    "marked": "^15.0.0",
    "marked-terminal": "^7.2.0",
    "openai": "^4.73.0",
    "ora": "^8.1.0",
    "pdf-parse": "^1.1.1",
    "tesseract.js": "^7.0.0",
    "tiktoken": "^1.0.18",
    "xlsx": "^0.18.5",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.10.0",
    "@types/yargs": "^17.0.0",
